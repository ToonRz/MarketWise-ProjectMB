<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Style for the label (e.g., "Open", "High") in the key stats grid -->
    <style name="KeyStatLabel" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:layout_gravity">start</item>
    </style>

    <!-- Style for the value (e.g., "$177.20", "$178.49") in the key stats grid -->
    <style name="KeyStatValue" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:layout_gravity">end</item>
    </style>

</resources>
